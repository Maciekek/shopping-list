NODE_ENV=production
PORT=3000

# Postgres (required)
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/shopping_list

# Public app URL (required for links and auth callbacks)
NEXTAUTH_URL=https://your-domain.example
AUTH_TRUST_HOST=true

# Session/auth secret (required)
# Generate: openssl rand -base64 32
AUTH_SECRET=replace-with-random-secret

# Google OAuth (required if login uses Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email provider (optional; required only for share emails)
POSTMARK_API_TOKEN=
